<#
.SYNOPSIS
  Open an Azure Bastion tunnel to {{ rdp_target_host }} (port 3389) and launch
  an RDP session through it.

.DESCRIPTION
  Generated by the `generate_rdp` Ansible role for `{{ rdp_environment_name }}`.
  Requires Azure CLI (`az`) and `mstsc` on the local Windows workstation. Picks
  a free local TCP port, starts `az network bastion tunnel`, waits for the
  tunnel to be reachable, writes a temporary .rdp pointing at it, launches
  mstsc, and tears the tunnel back down when mstsc exits.

.NOTES
  Target VM resource ID : {{ azure_rdp_target_resource_id }}
  Bastion               : {{ azure_rdp_bastion_name }}
  Bastion RG            : {{ azure_rdp_bastion_resource_group_name }}
  Subscription          : {{ azure_rdp_bastion_subscription_id }}
  Domain user           : {{ domain_admin_user }}
#>

[CmdletBinding()]
param(
    [string]$TargetResourceId     = '{{ azure_rdp_target_resource_id }}',
    [string]$BastionName          = '{{ azure_rdp_bastion_name }}',
    [string]$BastionResourceGroup = '{{ azure_rdp_bastion_resource_group_name }}',
    [string]$SubscriptionId       = '{{ azure_rdp_bastion_subscription_id }}',
    [string]$RdpUser              = '{{ domain_admin_user }}',
    [int]   $RemotePort           = 3389,
    [int]   $WaitSeconds          = 60
)

$ErrorActionPreference = 'Stop'

{% include '_ps_common.ps1.j2' %}

foreach ($value in @($TargetResourceId, $BastionName, $BastionResourceGroup, $SubscriptionId)) {
    if ([string]::IsNullOrWhiteSpace($value)) {
        throw 'Azure Bastion RDP launcher is missing required Bastion or target resource metadata.'
    }
}

if (-not (Get-Command az -ErrorAction SilentlyContinue)) {
    throw 'az not found on PATH. Install Azure CLI: https://learn.microsoft.com/cli/azure/install-azure-cli'
}
if (-not (Get-Command mstsc -ErrorAction SilentlyContinue)) {
    throw 'mstsc.exe not found on PATH.'
}

$localPort = Get-FreeTcpPort
$rdpFile = Join-Path $env:TEMP ("azure-bastion-rdp-{0}-{1}.rdp" -f '{{ rdp_target_host }}', [guid]::NewGuid().ToString('N').Substring(0,8))
$logFileOut = Join-Path $env:TEMP ("azure-bastion-rdp-{0}-{1}.out.log" -f '{{ rdp_target_host }}', $localPort)
$logFileErr = Join-Path $env:TEMP ("azure-bastion-rdp-{0}-{1}.err.log" -f '{{ rdp_target_host }}', $localPort)

Write-Host "Starting Azure Bastion tunnel $TargetResourceId`:$RemotePort -> localhost:$localPort"
Write-Host "Bastion=$BastionName ResourceGroup=$BastionResourceGroup Subscription=$SubscriptionId"
Write-Host "Tunnel logs: $logFileOut / $logFileErr"

$azArgs = @(
    'network', 'bastion', 'tunnel',
    '--name', $BastionName,
    '--resource-group', $BastionResourceGroup,
    '--target-resource-id', $TargetResourceId,
    '--resource-port', $RemotePort,
    '--port', $localPort,
    '--subscription', $SubscriptionId
)

$cmdArgs = @('/c', 'az') + $azArgs
$tunnel = Start-Process -FilePath 'cmd.exe' -ArgumentList $cmdArgs `
    -WindowStyle Hidden -PassThru `
    -RedirectStandardOutput $logFileOut -RedirectStandardError $logFileErr

try {
    $deadline = (Get-Date).AddSeconds($WaitSeconds)
    while ((Get-Date) -lt $deadline) {
        if ($tunnel.HasExited) {
            Get-Content $logFileOut -ErrorAction SilentlyContinue | Write-Host
            Get-Content $logFileErr -ErrorAction SilentlyContinue | Write-Host
            throw "Azure Bastion tunnel process exited (code $($tunnel.ExitCode)) before opening localhost:$localPort."
        }
        if (Test-LocalPort -Port $localPort) { break }
        Start-Sleep -Milliseconds 500
    }
    if (-not (Test-LocalPort -Port $localPort)) {
        Get-Content $logFileOut -ErrorAction SilentlyContinue | Write-Host
        Get-Content $logFileErr -ErrorAction SilentlyContinue | Write-Host
        throw "Timed out waiting $WaitSeconds s for Azure Bastion tunnel on localhost:$localPort."
    }

    @(
        "full address:s:localhost:$localPort"
        "username:s:$RdpUser"
        "authentication level:i:2"
        "enablecredsspsupport:i:1"
        "screen mode id:i:1"
        "use multimon:i:0"
    ) | Set-Content -Encoding ASCII -Path $rdpFile

    Write-Host "Launching mstsc against localhost:$localPort ..."
    $mstsc = Start-Process -FilePath 'mstsc' -ArgumentList @($rdpFile) -PassThru
    $mstsc.WaitForExit()
    Write-Host "mstsc exited (code $($mstsc.ExitCode))."
}
finally {
    if ($tunnel -and -not $tunnel.HasExited) {
        Write-Host "Stopping Azure Bastion tunnel (pid $($tunnel.Id))..."
        # cmd.exe spawned az (which spawned python). Kill the whole tree so the
        # actual tunnel process exits, not just the cmd shim.
        Stop-ProcessTree -ProcessId $tunnel.Id
    }
    if (Test-Path $rdpFile) { Remove-Item -Force -ErrorAction SilentlyContinue $rdpFile }
}
