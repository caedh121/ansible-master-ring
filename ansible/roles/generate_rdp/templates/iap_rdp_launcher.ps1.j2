<#
.SYNOPSIS
  Open a Google Cloud IAP tunnel to {{ rdp_target_host }} (port 3389) and
  launch an RDP session through it.

.DESCRIPTION
  Generated by the `generate_rdp` Ansible role for `{{ rdp_environment_name }}`.
  Self-contained: requires only the Google Cloud SDK (`gcloud`) and `mstsc`
  on the local Windows workstation. Picks a free local TCP port, starts the
  IAP tunnel as a background process, waits for the tunnel to be reachable,
  writes a temporary .rdp pointing at it, launches mstsc, and tears the
  tunnel back down when mstsc exits.

.NOTES
  Target VM    : {{ rdp_target_host }}
  GCP project  : {{ gcp_rdp_project }}
  GCP zone     : {{ gcp_rdp_zone }}
  IAP config   : {{ gcp_rdp_configuration }}
  Domain user  : {{ domain_admin_user }}
#>

[CmdletBinding()]
param(
    [string]$TargetVm    = '{{ rdp_target_host }}',
    [string]$GcpProject  = '{{ gcp_rdp_project }}',
    [string]$GcpZone     = '{{ gcp_rdp_zone }}',
    [string]$GcpConfig   = '{{ gcp_rdp_configuration }}',
    [string]$RdpUser     = '{{ domain_admin_user }}',
    [int]   $RemotePort  = 3389,
    [int]   $WaitSeconds = 30
)

$ErrorActionPreference = 'Stop'

{% include '_ps_common.ps1.j2' %}

if (-not (Get-Command gcloud -ErrorAction SilentlyContinue)) {
    throw "gcloud not found on PATH. Install Google Cloud SDK: https://cloud.google.com/sdk/docs/install"
}
if (-not (Get-Command mstsc -ErrorAction SilentlyContinue)) {
    throw "mstsc.exe not found on PATH."
}

$localPort  = Get-FreeTcpPort
$rdpFile    = Join-Path $env:TEMP ("iap-rdp-{0}-{1}.rdp" -f $TargetVm, [guid]::NewGuid().ToString('N').Substring(0,8))
$logFileOut = Join-Path $env:TEMP ("iap-rdp-{0}-{1}.out.log" -f $TargetVm, $localPort)
$logFileErr = Join-Path $env:TEMP ("iap-rdp-{0}-{1}.err.log" -f $TargetVm, $localPort)

Write-Host "Starting IAP tunnel  $TargetVm`:$RemotePort  ->  localhost:$localPort"
Write-Host "Project=$GcpProject  Zone=$GcpZone  Configuration=$GcpConfig"
Write-Host "Tunnel logs: $logFileOut  /  $logFileErr"

$gcloudArgs = @(
    'compute','start-iap-tunnel', $TargetVm, $RemotePort,
    "--project=$GcpProject",
    "--zone=$GcpZone",
    "--local-host-port=localhost:$localPort",
    "--configuration=$GcpConfig"
)

# gcloud on Windows is gcloud.cmd (a batch shim), not a PE binary.
# Start-Process with -RedirectStandardOutput requires a real executable,
# so wrap the call in cmd.exe /c.
$cmdArgs = @('/c','gcloud') + $gcloudArgs
$tunnel = Start-Process -FilePath 'cmd.exe' -ArgumentList $cmdArgs `
    -WindowStyle Hidden -PassThru `
    -RedirectStandardOutput $logFileOut -RedirectStandardError $logFileErr

try {
    $deadline = (Get-Date).AddSeconds($WaitSeconds)
    while ((Get-Date) -lt $deadline) {
        if ($tunnel.HasExited) {
            Get-Content $logFileOut -ErrorAction SilentlyContinue | Write-Host
            Get-Content $logFileErr -ErrorAction SilentlyContinue | Write-Host
            throw "IAP tunnel process exited (code $($tunnel.ExitCode)) before opening localhost:$localPort."
        }
        if (Test-LocalPort -Port $localPort) { break }
        Start-Sleep -Milliseconds 500
    }
    if (-not (Test-LocalPort -Port $localPort)) {
        Get-Content $logFileOut -ErrorAction SilentlyContinue | Write-Host
        Get-Content $logFileErr -ErrorAction SilentlyContinue | Write-Host
        throw "Timed out waiting $WaitSeconds s for IAP tunnel on localhost:$localPort."
    }

    @(
        "full address:s:localhost:$localPort"
        "username:s:$RdpUser"
        "authentication level:i:2"
        "enablecredsspsupport:i:1"
        "screen mode id:i:1"
        "use multimon:i:0"
    ) | Set-Content -Encoding ASCII -Path $rdpFile

    Write-Host "Launching mstsc against localhost:$localPort ..."
    $mstsc = Start-Process -FilePath 'mstsc' -ArgumentList @($rdpFile) -PassThru
    $mstsc.WaitForExit()
    Write-Host "mstsc exited (code $($mstsc.ExitCode))."
}
finally {
    if ($tunnel -and -not $tunnel.HasExited) {
        Write-Host "Stopping IAP tunnel (pid $($tunnel.Id))..."
        # cmd.exe spawned gcloud (which spawned python). Kill the whole tree
        # so the actual tunnel process exits, not just the cmd shim.
        Stop-ProcessTree -ProcessId $tunnel.Id
    }
    if (Test-Path $rdpFile) { Remove-Item -Force -ErrorAction SilentlyContinue $rdpFile }
}
