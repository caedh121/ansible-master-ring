---
extends: default

ignore: |
  .github/
  ansible/rdp_artifacts/
  *.tar.gz

rules:
  line-length:
    max: 160
    level: warning
  truthy:
    check-keys: false
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  document-start: disable
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
